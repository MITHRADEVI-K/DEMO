{
  "name": "demo-project",
  "version": "1.0.0",
  "description": "Demo project with CodeRabbit automated testing",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:generate": "node scripts/generate-tests.js",
    "test:performance": "node scripts/performance-test.js",
    "test:validation": "node scripts/validation-test.js",
    "test:errors": "node scripts/error-test.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:complexity": "eslint . --ext .js,.jsx,.ts,.tsx --plugin sonarjs/recommended",
    "build": "echo 'Build step - add your build command here'",
    "sonar": "sonar-scanner",
    "kpi-report": "node scripts/generate-kpi-report.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "eslint": "^8.54.0",
    "eslint-plugin-sonarjs": "^0.23.0",
    "jest": "^29.7.0",
    "sonarqube-scanner": "^3.3.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.{js,jsx,ts,tsx}",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!**/build/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 85,
        "lines": 80,
        "statements": 80
      }
    },
    "testMatch": [
      "**/__tests__/**/*.{js,jsx,ts,tsx}",
      "**/*.{test,spec}.{js,jsx,ts,tsx}"
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "node": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:sonarjs/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "plugins": [
      "sonarjs"
    ],
    "rules": {
      "sonarjs/cognitive-complexity": ["error", 15],
      "sonarjs/no-duplicate-string": ["error", 5]
    }
  }
}