{
  "coderabbit": {
    "rules": [
      {
        "name": "Cyclomatic Complexity Check",
        "enabled": true,
        "threshold": 15,
        "error_message": "Function complexity exceeds {threshold}. Current: {actual}",
        "file_types": ["js", "html"]
      },
      {
        "name": "UI Performance Check",
        "enabled": true,
        "load_time_ms": 3000,
        "error_message": "UI load time exceeds {threshold}ms",
        "file_types": ["js", "html", "css"]
      },
      {
        "name": "Accessibility Check",
        "enabled": true,
        "threshold": 95,
        "error_message": "Accessibility score below {threshold}%. Current: {actual}%"
      },
      {
        "name": "UI State Coverage Check",
        "enabled": true,
        "threshold": 80,
        "error_message": "UI state coverage below {threshold}%. Current: {actual}%"
      },
      {
        "name": "User Flow Check",
        "enabled": true,
        "threshold": 85,
        "error_message": "User flow coverage below {threshold}%. Current: {actual}%"
      }
    ],
    "exclusions": {
      "paths": [
        "node_modules/",
        "dist/",
        "build/",
        ".next/",
        "coverage/",
        ".git/"
      ],
      "files": [
        "*.min.js",
        "*.min.css",
        "*.lock",
        ".env*"
      ]
    },
    "notifications": {
      "slack": {
        "enabled": true,
        "webhook_url": "${SLACK_WEBHOOK_URL}",
        "notify_on": ["ui_issue", "performance_degradation", "accessibility_violation"]
      },
      "github": {
        "enabled": true,
        "create_issue": false,
        "comment_on_pr": true,
        "require_review": false
      },
      "email": {
        "enabled": false,
        "recipients": []
      }
    }
  },
  "kpi_definitions": {
    "frontend_quality": {
      "metrics": [
        {
          "id": "cyclomatic_complexity",
          "name": "Cyclomatic Complexity",
          "target": 15,
          "unit": "score",
          "importance": "critical",
          "description": "Measures code path complexity in UI logic"
        },
        {
          "id": "maintainability_index",
          "name": "Maintainability Index",
          "target": 50,
          "unit": "score",
          "importance": "high",
          "description": "Overall code maintainability score (0-100)"
        },
        {
          "id": "code_duplication",
          "name": "Code Duplication",
          "target": 5,
          "unit": "percent",
          "importance": "medium",
          "description": "Percentage of duplicated UI code"
        }
      ]
    },
    "frontend_performance": {
      "metrics": [
        {
          "id": "load_time",
          "name": "Page Load Time",
          "target": 3000,
          "unit": "milliseconds",
          "importance": "critical",
          "description": "Time to load initial page"
        },
        {
          "id": "dom_interactions",
          "name": "DOM Interactions",
          "target": 1000,
          "unit": "count",
          "importance": "high",
          "description": "Number of DOM manipulations per session"
        },
        {
          "id": "memory_usage",
          "name": "Memory Usage",
          "target": 256,
          "unit": "MB",
          "importance": "medium",
          "description": "Peak memory usage"
        }
      ]
    },
    "ui_coverage": {
      "metrics": [
        {
          "id": "ui_state_coverage",
          "name": "UI State Coverage",
          "target": 80,
          "unit": "percent",
          "importance": "critical",
          "description": "Percentage of UI states tested"
        },
        {
          "id": "user_flow_coverage",
          "name": "User Flow Coverage",
          "target": 85,
          "unit": "percent",
          "importance": "high",
          "description": "Percentage of user flows tested"
        },
        {
          "id": "accessibility_compliance",
          "name": "Accessibility Compliance",
          "target": 100,
          "unit": "percent",
          "importance": "critical",
          "description": "WCAG compliance percentage"
        }
      ]
    }
  },
  "test_relevance_rules": {
    "ui_components": {
      "required": true,
      "min_test_coverage": 80,
      "reason": "UI components must be tested to ensure proper rendering and interaction"
    },
    "user_flows": {
      "required": true,
      "min_test_coverage": 85,
      "reason": "Critical user flows must be 100% tested to prevent UX regressions"
    },
    "accessibility": {
      "required": true,
      "min_test_coverage": 100,
      "reason": "Accessibility features must be tested for compliance"
    },
    "edge_cases": {
      "required": true,
      "reason": "Edge cases and boundary conditions must be tested for UI robustness"
    },
    "error_states": {
      "required": true,
      "reason": "Error handling in UI must be tested to ensure graceful failure"
    }
  },
  "constraint_definitions": {
    "must_pass_ui_tests": {
      "enabled": true,
      "blocking": true,
      "message": "All UI tests must pass before merging"
    },
    "must_meet_accessibility": {
      "enabled": true,
      "threshold": 95,
      "blocking": true,
      "message": "Accessibility score must be above 95%"
    },
    "must_not_increase_complexity": {
      "enabled": true,
      "threshold": 15,
      "blocking": true,
      "message": "Do not increase cyclomatic complexity beyond 15"
    },
    "must_document_ui_changes": {
      "enabled": true,
      "blocking": false,
      "message": "All UI changes should have documentation updates"
    },
    "must_handle_user_input": {
      "enabled": true,
      "blocking": true,
      "message": "All user inputs must be properly handled"
    }
  }
}
